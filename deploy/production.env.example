# Copy to .env on the Tencent Cloud server. Never commit the real .env.

BIND_HOST=127.0.0.1
SERVER_PORT=8080
TZ=Asia/Shanghai
RUN_MODE=standard

# Required secrets
POSTGRES_USER=sub2api
POSTGRES_PASSWORD=replace-with-a-strong-password
POSTGRES_DB=sub2api
JWT_SECRET=replace-with-openssl-rand-hex-32
TOTP_ENCRYPTION_KEY=replace-with-openssl-rand-hex-32

# Admin account; leave ADMIN_PASSWORD empty only when intentionally using auto-setup.
ADMIN_EMAIL=admin@modurelay.local
ADMIN_PASSWORD=
JWT_EXPIRE_HOUR=24

# Low-memory production defaults. Tune after observing the server.
DATABASE_MAX_OPEN_CONNS=30
DATABASE_MAX_IDLE_CONNS=10
REDIS_POOL_SIZE=100
REDIS_MIN_IDLE_CONNS=10

MODURELAY_MEMORY_LIMIT=1536m
MODURELAY_CPU_LIMIT=1.50
POSTGRES_MEMORY_LIMIT=1024m
POSTGRES_CPU_LIMIT=1.00
REDIS_MEMORY_LIMIT=512m
REDIS_CPU_LIMIT=0.50
REDIS_MAXMEMORY=384mb
REDIS_MAXMEMORY_POLICY=allkeys-lru

DOCKER_LOG_MAX_SIZE=20m
DOCKER_LOG_MAX_FILE=3
LOG_LEVEL=info
LOG_FORMAT=json
LOG_CALLER=false
LOG_OUTPUT_TO_STDOUT=true
LOG_OUTPUT_TO_FILE=false

# Leave empty when the server has direct outbound access.
# For a host proxy, make sure the port and protocol actually match the proxy service.
HTTP_PROXY=
HTTPS_PROXY=
ALL_PROXY=
NO_PROXY=localhost,127.0.0.1,::1,modurelay,postgres,redis
http_proxy=
https_proxy=
all_proxy=
no_proxy=localhost,127.0.0.1,::1,modurelay,postgres,redis

# Example when the host exposes an HTTP proxy on 7891 and SOCKS5 on 7892:
# HTTP_PROXY=http://host.docker.internal:7891
# HTTPS_PROXY=http://host.docker.internal:7891
# ALL_PROXY=socks5h://host.docker.internal:7892
# http_proxy=http://host.docker.internal:7891
# https_proxy=http://host.docker.internal:7891
# all_proxy=socks5h://host.docker.internal:7892

# Optional provider, payment and security variables may be kept here. The app service
# receives this server-side .env through env_file without putting secrets in the image.
